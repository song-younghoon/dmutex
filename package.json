{
  "name": "dmutex",
  "version": "0.3.0",
  "description": "A small TypeScript distributed mutex and semaphore library for MongoDB, Redis, and PostgreSQL.",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/song-younghoon/dmutex.git"
  },
  "keywords": [
    "distributed-lock",
    "distributed-semaphore",
    "mutex",
    "semaphore",
    "mongodb",
    "dynamodb",
    "cloudflare-d1",
    "firestore",
    "mysql",
    "postgresql",
    "redis",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "bun run test:unit",
    "test:unit": "bun test tests/unit",
    "test:integration": "DMUTEX_INTEGRATION=1 bun test tests/integration",
    "test:integration:docker": "bash scripts/test-integration-docker.sh",
    "test:d1:unit": "bun test tests/unit/d1.test.ts",
    "test:dynamodb": "DMUTEX_INTEGRATION=1 bun test tests/unit/dynamodb.test.ts tests/integration/dynamodb.integration.test.ts",
    "test:dynamodb:unit": "bun test tests/unit/dynamodb.test.ts",
    "test:dynamodb:integration": "DMUTEX_INTEGRATION=1 bun test tests/integration/dynamodb.integration.test.ts",
    "test:firestore:unit": "bun test tests/unit/firestore.test.ts",
    "test:mongodb": "DMUTEX_INTEGRATION=1 bun test tests/integration/mongo.integration.test.ts",
    "test:mysql": "DMUTEX_INTEGRATION=1 bun test tests/unit/mysql.test.ts tests/integration/mysql.integration.test.ts",
    "test:mysql:unit": "bun test tests/unit/mysql.test.ts",
    "test:mysql:integration": "DMUTEX_INTEGRATION=1 bun test tests/integration/mysql.integration.test.ts",
    "test:postgres": "DMUTEX_INTEGRATION=1 bun test tests/unit/postgres.test.ts tests/integration/postgres.integration.test.ts",
    "test:postgres:unit": "bun test tests/unit/postgres.test.ts",
    "test:postgres:integration": "DMUTEX_INTEGRATION=1 bun test tests/integration/postgres.integration.test.ts",
    "test:redis": "DMUTEX_INTEGRATION=1 bun test tests/unit/redis.test.ts tests/integration/redis.integration.test.ts",
    "test:redis:unit": "bun test tests/unit/redis.test.ts",
    "test:redis:integration": "DMUTEX_INTEGRATION=1 bun test tests/integration/redis.integration.test.ts",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1056.0",
    "@types/bun": "latest",
    "ioredis": "^5.10.1",
    "mongodb": ">=4.0.0",
    "mysql2": "^3.22.4",
    "pg": "^8.21.0",
    "redis": "^5.12.1",
    "typescript": "^5"
  }
}
